# zeb Echo backend — environment configuration.
# Copy to `.env` and fill in secrets. `.env` is git-ignored; NEVER commit tokens.

# --- Server ---
PORT=8787
HOST=127.0.0.1

# --- LLM provider selection: ollama | cloudflare | fake ---
LLM_PROVIDER=cloudflare

# --- Cloudflare Workers AI (provider=cloudflare) ---
CF_ACCOUNT_ID=ffa322284ed541fda4f23139c62101de
CF_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct
# SECRET — create at: Cloudflare dashboard → AI → Workers AI → "Use REST API"
# (token needs the "Workers AI" permission). Paste it in .env, not here.
CF_API_TOKEN=

# --- Token proxy (shipped desktop app) ---
# When set, ALL Workers AI calls (LLM + Whisper) go through this proxy Worker,
# which holds the token server-side — so the packaged app ships NO secret and
# CF_API_TOKEN can be left blank. Leave empty for local dev (direct-to-Cloudflare
# using CF_API_TOKEN). See worker/ for the proxy source + deploy steps.
# CF_GATEWAY_URL=https://zeb-echo-proxy.<your-subdomain>.workers.dev
# Optional shared bearer the proxy requires (matches the Worker's
# PROXY_SHARED_SECRET). Gates the proxy; far lower-value than the CF token.
# CF_GATEWAY_TOKEN=

# --- Speech-to-text (Cloudflare Whisper — no local model, low memory) ---
TRANSCRIPTION_ENGINE=cloudflare           # cloudflare | fake
CF_WHISPER_MODEL=@cf/openai/whisper-large-v3-turbo

# --- Backend audio capture (ffmpeg avfoundation) ---
AUDIO_SOURCE=blackhole                    # blackhole (ffmpeg capture) | none (client-fed/fake)
AUDIO_DEVICE_INDEX=1                       # run `npm run devices` to find the index

# --- Ollama (provider=ollama) ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
