{
  "name": "zeb-echo-backend",
  "version": "0.1.0",
  "description": "Local Node/TypeScript backend for zeb Echo — hosts the AI meeting-assistant pipeline and serves a localhost WebSocket.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node22-macos-arm64",
      "node22-macos-x64",
      "node22-win-x64"
    ],
    "outputPath": "build",
    "assets": []
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/index.js",
    "devices": "tsx src/audio/listDevices.ts",
    "devclient": "tsx src/devClient.ts",
    "package": "npm run build && pkg .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@yao-pkg/pkg": "^6.20.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
